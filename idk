                    if not ConfigText then return end
                    Library:DeleteConfig(ConfigText)
                    ConfigHolder:UpdateConfigList()
                end})
                :AddButton({Text = "Refresh", Confirmation = true, Callback = function()
                    ConfigHolder:UpdateConfigList()
                end})
