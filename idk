                    math.clamp(Parent.Instance.Position.X.Offset, 0, Horizontal - Parent.Instance.Size.X.Offset),
                    0,
                    math.clamp(Parent.Instance.Position.Y.Offset, 0, Vertical - Parent.Instance.Size.Y.Offset)
