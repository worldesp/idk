            Tab.OpenPage = function(self)
                if self.Tweening then return end
                local Window = self.Window
                local OldTab = Window.TabInfo
                local Items = self.Items
                if OldTab == self or (self.Tweening or (OldTab and OldTab.Tweening)) then return end
                if OldTab then
                    local OldItems = OldTab.Items
                    OldItems.Button:Tween({BackgroundColor3 = Themes.Preset.TabButtonUnselected})
                    OldItems.Title:Tween({TextColor3 = Themes.Preset.TextMisc})
                    OldItems.Icon:Tween({ImageColor3 = Themes.Preset.TextMisc})
                    OldItems.Page:TweenDescendants(false, OldTab)
                    OldItems.Page.Parent = self.Window.Items.ContentArea -- keep parent
                end
                Items.Button:Tween({BackgroundColor3 = Themes.Preset.Accent})
                Items.Title:Tween({TextColor3 = Themes.Preset.TextMain})
                Items.Icon:Tween({ImageColor3 = Themes.Preset.TextMain})
                Items.Page:TweenDescendants(true, self)
                self.Window.TabInfo = self
            end

            Items.Button:OnClick(function()
                Tab:OpenPage()
            end)

            -- If first tab, select it
            if not self.TabInfo then
                Tab:OpenPage()
            end

            return Tab
        end

